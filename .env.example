# API-Football (api-sports.io) のキーを入れる。
# 取得: https://dashboard.api-football.com/register (無料、100 req/日)
# ⚠️ Free プランは 2022-2024 シーズンのみ。W 杯 2026 は Pro プラン (有料) 必須。
#
# このファイルはサンプル。実際のキーは `.env.local` に書く (gitignore で除外)。
#
# 使う場所: vite.config.ts の `/api-football/*` プロキシが
#           リクエストに `x-apisports-key` ヘッダとして自動付与する。
VITE_API_FOOTBALL_KEY=your-api-football-key-here

# Football-Data.org v4 のキーを入れる。
# 取得: https://www.football-data.org/client/register (無料、10 req/分)
# 無料枠 (Tier One) で W 杯 2026 のスコア・順位・得点者ランキングが取れる。
# ⚠️ フォーメーション・得点者の時系列・カード・交代は取れない (基本データのみ)。
#
# 使う場所: vite.config.ts の `/football-data-api/*` プロキシが
#           リクエストに `X-Auth-Token` ヘッダとして自動付与する。
VITE_FOOTBALL_DATA_KEY=your-football-data-key-here
